{
  "name": "@delta-mcp/core",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Core MCP2 protocol types, transport, and progressive disclosure",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./benchmark": {
      "types": "./dist/benchmark/token-counter.d.ts",
      "import": "./dist/benchmark/token-counter.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/norhther/delta-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "cbor-x": "^1.5.0"
  }
}
