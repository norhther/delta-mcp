{
  "name": "delta-mcp",
  "version": "0.2.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "description": "Token-efficient MCP reimplementation",
  "workspaces": [
    "packages/*",
    "conformance"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "conformance": "cd conformance && vitest run --config vitest.config.ts",
    "lint": "eslint packages/*/src/**/*.ts",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
